@model WebSmartSchedule.Pages.Cabinet.IndexModel

<!-- Модальное окно создания кабинета -->
<div id="createCabinetModal" class="modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
    <div class="modal-content">
        <button class="btn-close" onclick="closeModal('createCabinetModal')"></button>
        <div class="modal-header mb-3">
            <h3>Добавить новый кабинет</h3>
        </div>
        <form id="createCabinetForm" method="post" asp-page-handler="Create" class="needs-validation" novalidate>
            <div class="form-group">
                <label for="createCabinetNumber" class="form-label">Номер кабинета</label>
                <input type="text" class="form-control" id="createCabinetNumber" name="Number"
                       required maxlength="10" minlength="1"
                       pattern="^[a-zA-Zа-яА-Я0-9\-]+$"
                       oninput="this.value = this.value.replace(/[^a-zA-Zа-яА-Я0-9\-]/g, '')"
                       placeholder="Например: 101А или Б-203"
                       data-bs-toggle="tooltip"
                       data-bs-placement="top"
                       title="Только буквы, цифры и дефис. Без пробелов (макс. 10)">
                <div class="invalid-feedback">Только буквы, цифры и дефис (без пробелов)</div>
            </div>
            <div class="form-group">
                <label for="createCabinetBuildingId" class="form-label">Корпус</label>
                <select name="BuildingId" class="form-control" id="createCabinetBuildingId" required
                        data-bs-toggle="tooltip" title="Выберите корпус из списка">
                    <option value="">-- Выберите корпус --</option>
                    @foreach (var building in Model.Buildings)
                    {
                        <option value="@building.Id">@building.Name</option>
                    }
                </select>
                <div class="invalid-feedback">Выберите корпус</div>
            </div>
            <div class="form-group">
                <label for="createCabinetCapacity" class="form-label">Вместимость</label>
                <input type="number" class="form-control" id="createCabinetCapacity" name="Capacity"
                       required min="1" max="50"
                       oninput="this.value = this.value.replace(/[^0-9]/g, ''); if(this.value > 50) this.value = 50; if(this.value < 1 && this.value !== '') this.value = '';"
                       data-bs-toggle="tooltip"
                       data-bs-placement="top"
                       title="Количество мест (от 1 до 50)">
                <div class="invalid-feedback">От 1 до 50 человек</div>
            </div>
            <div class="form-group">
                <label for="createCabinetEquipment" class="form-label">Оборудование</label>
                <textarea class="form-control" id="createCabinetEquipment" name="Equipment"
                          rows="3" maxlength="200"
                          data-bs-toggle="tooltip"
                          data-bs-placement="top"
                          title="Краткое описание оборудования (макс. 200 символов)"></textarea>
                <div class="invalid-feedback">Максимум 200 символов</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('createCabinetModal')">Отмена</button>
                <button type="submit" class="btn btn-primary">Добавить</button>
            </div>
        </form>
    </div>
</div>

<div id="editCabinetModal" class="modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
    <div class="modal-content">
        <button class="btn-close" onclick="closeModal('editCabinetModal')"></button>
        <div class="modal-header mb-3">
            <h3>Редактировать кабинет</h3>
        </div>
        <form method="post" asp-page-handler="Update" class="needs-validation" novalidate>
            <input type="hidden" id="editCabinetId" name="Id">
            <div class="form-group">
                <label for="editCabinetNumber" class="form-label">Номер кабинета</label>
                <input type="text" class="form-control" id="editCabinetNumber" name="Number"
                       required maxlength="10" minlength="1"
                       pattern="^[a-zA-Zа-яА-Я0-9\-]+$"
                       oninput="this.value = this.value.replace(/[^a-zA-Zа-яА-Я0-9\-]/g, '')"
                       data-bs-toggle="tooltip"
                       data-bs-placement="top"
                       title="Только буквы, цифры и дефис. Без пробелов (макс. 10)">
                <div class="invalid-feedback">Только буквы, цифры и дефис</div>
            </div>
            <div class="form-group">
                <label for="editCabinetBuildingId" class="form-label">Корпус</label>
                <select name="BuildingId" class="form-control" id="editCabinetBuildingId" required
                        data-bs-toggle="tooltip" title="Выберите корпус из списка">
                    <option value="">-- Выберите корпус --</option>
                    @foreach (var building in Model.Buildings)
                    {
                        <option value="@building.Id">@building.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label for="editCabinetCapacity" class="form-label">Вместимость</label>
                <input type="number" class="form-control" id="editCabinetCapacity" name="Capacity"
                       required min="1" max="50"
                       oninput="this.value = this.value.replace(/[^0-9]/g, ''); if(this.value > 50) this.value = 50; if(this.value < 1 && this.value !== '') this.value = '';"
                       data-bs-toggle="tooltip"
                       data-bs-placement="top"
                       title="Количество мест (от 1 до 50)">
            </div>
            <div class="form-group">
                <label for="editCabinetEquipment" class="form-label">Оборудование</label>
                <textarea class="form-control" id="editCabinetEquipment" name="Equipment"
                          rows="3" maxlength="200"
                          data-bs-toggle="tooltip"
                          data-bs-placement="top"
                          title="Краткое описание оборудования (макс. 200 символов)"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('editCabinetModal')">Отмена</button>
                <button type="submit" class="btn btn-primary">Сохранить</button>
            </div>
        </form>
    </div>
</div>

<!-- Модальное окно подтверждения удаления -->
<div id="deleteConfirmModal" class="modal">
    <div class="modal-content">
        <button class="btn-close" onclick="closeModal('deleteConfirmModal')">&times;</button>
        <div class="modal-header mb-3">
            <h3>Подтверждение удаления</h3>
        </div>
        <form method="post" asp-page-handler="Delete">
            <input type="hidden" id="deleteCabinetId" name="Id" />
            <p>Вы уверены, что хотите удалить этот кабинет? Это действие нельзя будет отменить.</p>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('deleteConfirmModal')">Отмена</button>
                <button type="submit" class="btn btn-danger">Удалить</button>
            </div>
        </form>
    </div>
</div>
