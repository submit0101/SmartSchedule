@page
@model WebSmartSchedule.Pages.WeekTypes.IndexModel
@{
    ViewData["Title"] = "Тип недели";
}
<link rel="stylesheet" href="~/css/UnionStyle.css" />
<div class="container-xxl py-4">
    <div class="page-section p-4 bg-white rounded shadow-sm">
        <!-- Сообщения -->
        @if (TempData["WTSuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["WTSuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["WTErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["WTErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <!-- Заголовок и кнопка добавления -->
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
            <h2 class="mb-0 text-primary fw-bold">📅 Типы недель</h2>
            <a href="#"
               class="btn btn-success px-3 py-2 d-flex align-items-center gap-2"
               onclick="openModal('createWeekTypeModal')">
                <i class="bi bi-plus-lg"></i> Добавить тип недели
            </a>
        </div>
        <!-- Результаты -->
        @if (!Model.WeekTypes.Any())
        {
            <div class="text-center py-5 bg-light rounded">
                <p class="lead mb-2">Нет данных о типах недель.</p>
                <p class="text-muted">Добавьте их через Swagger или миграции.</p>
            </div>
        }
        else
        {
            <!-- Карточки для мобильных устройств -->
            <div class="d-block d-md-none mt-3" style="max-height: 60vh; overflow-y: auto;">
                <div class="container-fluid p-0">
                    @foreach (var weekType in Model.WeekTypes)
                    {
                        <div class="card mb-3 shadow-sm">
                            <div class="card-body">
                                <h5 class="card-title">@weekType.Name</h5>
                                <div class="d-flex gap-2 mt-3">
                                    <button class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1"
                                            onclick="fillEditWeekTypeModal(this)"
                                            data-id="@weekType.Id"
                                            data-name="@weekType.Name">
                                        <i class="bi bi-pencil"></i> Изменить
                                    </button>
                                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="confirmDeleteWeekType(@weekType.Id)">
                                        Удалить
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <!-- Таблица для десктопа -->
            <div class="table-container border rounded overflow-auto d-none d-md-block mt-3" style="max-height: 60vh;">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th>Название</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var weekType in Model.WeekTypes)
                        {
                            <tr>
                                <td data-label="Название">@weekType.Name</td>
                                <td data-label="Действия">
                                    <div class="d-flex justify-content-center gap-2">
                                        <button class="btn btn-sm btn-outline-primary"
                                                onclick="fillEditWeekTypeModal(this)"
                                                data-id="@weekType.Id"
                                                data-name="@weekType.Name">
                                            <i class="bi bi-pencil"></i> Изменить
                                        </button>
                                        <button type="button" class="btn btn-outline-danger btn-sm"
                                                onclick="confirmDeleteWeekType(@weekType.Id)">
                                            Удалить
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<partial name="_WeekTypeModals" />

<script>
    function fillEditWeekTypeModal(button) {
        const id = button.getAttribute('data-id');
        const name = button.getAttribute('data-name');
        document.getElementById('editWeekTypeId').value = id;
        document.getElementById('editWeekTypeName').value = name;
        openModal('editWeekTypeModal');
    }

    function confirmDeleteWeekType(id) {
        document.getElementById('deleteWeekTypeId').value = id;
        openModal('deleteWeekTypeConfirmModal');
    }
</script>
<script src="/js/modal.js"></script>
<script src="/js/ValidationModal.js"></script>