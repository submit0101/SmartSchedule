<link rel="stylesheet" href="~/css/UnionStyle.css" />

<div id="createTimeSlotModal" class="modal">
    <div class="modal-content">
        <button class="btn-close" onclick="closeModal('createTimeSlotModal')">&times;</button>
        <div class="modal-header mb-3">
            <h3>Добавить новый временной слот</h3>
        </div>
        <form id="createTimeSlotForm" method="post" asp-page-handler="Create" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label for="createSlotNumber" class="form-label">Номер слота</label>
                <input type="number" name="SlotNumber" id="createSlotNumber"
                       class="form-control" required min="1" max="20"
                       onkeypress="return event.charCode >= 48 && event.charCode <= 57"
                       oninput="if(this.value == 0) this.value = ''; if(this.value > 20) this.value = 20;"
                       placeholder="1-20"
                       title="Порядковый номер слота (1-20)">
                <div class="invalid-feedback">Пожалуйста, укажите номер слота (1-20).</div>
            </div>
            <div class="form-group">
                <label for="createStartTime" class="form-label">Время начала</label>
                <input type="time" name="StartTime" id="createStartTime"
                       class="form-control" required
                       placeholder="08:00"
                       title="Время начала занятия (формат: ЧЧ:ММ)">
                <div class="invalid-feedback">Пожалуйста, укажите время начала.</div>
            </div>
            <div class="form-group">
                <label for="createEndTime" class="form-label">Время окончания</label>
                <input type="time" name="EndTime" id="createEndTime"
                       class="form-control" required
                       placeholder="09:30"
                       title="Время окончания занятия (формат: ЧЧ:ММ)">
                <div class="invalid-feedback">Пожалуйста, укажите время окончания.</div>
            </div>
            <div id="createTimeError" class="alert alert-danger" style="display: none;">
                Время окончания должно быть позже времени начала.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('createTimeSlotModal')">Отмена</button>
                <button type="submit" class="btn btn-primary">Добавить</button>
            </div>
        </form>
    </div>
</div>

<div id="editTimeSlotModal" class="modal">
    <div class="modal-content">
        <button class="btn-close" onclick="closeModal('editTimeSlotModal')">&times;</button>
        <div class="modal-header mb-3">
            <h3>Редактировать временной слот</h3>
        </div>
        <form method="post" asp-page-handler="Update" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" id="editTimeSlotId" name="Id" />
            <div class="form-group">
                <label for="editSlotNumber" class="form-label">Номер слота</label>
                <input type="number" name="SlotNumber" id="editSlotNumber"
                       class="form-control" required min="1" max="20"
                       onkeypress="return event.charCode >= 48 && event.charCode <= 57"
                       oninput="if(this.value == 0) this.value = ''; if(this.value > 20) this.value = 20;"
                       placeholder="1-20"
                       title="Порядковый номер слота (1-20)">
                <div class="invalid-feedback">Пожалуйста, укажите номер слота (1-20).</div>
            </div>
            <div class="form-group">
                <label for="editStartTime" class="form-label">Время начала</label>
                <input type="time" name="StartTime" id="editStartTime"
                       class="form-control" required
                       placeholder="08:00"
                       title="Время начала занятия (формат: ЧЧ:ММ)">
                <div class="invalid-feedback">Пожалуйста, укажите время начала.</div>
            </div>
            <div class="form-group">
                <label for="editEndTime" class="form-label">Время окончания</label>
                <input type="time" name="EndTime" id="editEndTime"
                       class="form-control" required
                       placeholder="09:30"
                       title="Время окончания занятия (формат: ЧЧ:ММ)">
                <div class="invalid-feedback">Пожалуйста, укажите время окончания.</div>
            </div>
            <div id="editTimeError" class="alert alert-danger" style="display: none;">
                Время окончания должно быть позже времени начала.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('editTimeSlotModal')">Отмена</button>
                <button type="submit" class="btn btn-primary">Сохранить</button>
            </div>
        </form>
    </div>
</div>

<div id="deleteConfirmModal" class="modal">
    <div class="modal-content">
        <button class="btn-close" onclick="closeModal('deleteConfirmModal')">&times;</button>
        <div class="modal-header mb-3">
            <h3>Подтверждение удаления</h3>
        </div>
        <form method="post" asp-page-handler="Delete">
            @Html.AntiForgeryToken()
            <input type="hidden" id="deleteTimeSlotId" name="Id" />
            <p>Вы уверены, что хотите удалить этот временной слот? Это действие нельзя будет отменить.</p>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('deleteConfirmModal')">Отмена</button>
                <button type="submit" class="btn btn-danger">Удалить</button>
            </div>
        </form>
    </div>
</div>