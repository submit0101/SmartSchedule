@page
@model IndexModel
@using System.Globalization
@{
    ViewData["Title"] = "Главная";

    DateTime today = DateTime.Now;
    CultureInfo myCI = new CultureInfo("ru-RU");
    Calendar myCal = myCI.Calendar;

    int isoWeek = myCal.GetWeekOfYear(today, CalendarWeekRule.FirstFourDayWeek, DayOfWeek.Monday);
    int weekOffset = -1;
    int weekNumber = isoWeek + weekOffset;

    bool isEvenWeek = weekNumber % 2 == 0;
    string weekType = isEvenWeek ? "Знаменатель" : "Числитель";
    string badgeClass = isEvenWeek ? "bg-indigo-soft text-indigo" : "bg-orange-soft text-orange";
}

<style>
    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: 100vh;
    }

    .bg-indigo-soft {
        background-color: #e0e7ff;
    }

    .text-indigo {
        color: #4338ca;
    }

    .bg-orange-soft {
        background-color: #ffedd5;
    }

    .text-orange {
        color: #c2410c;
    }

    .dashboard-wrapper {
        min-height: calc(100vh - 60px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        overflow: hidden;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 24px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
        height: 100%;
        transition: transform 0.3s ease;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .info-card-content {
        position: relative;
        z-index: 2;
        width: 100%;
    }

    .glass-card::before {
        content: '';
        position: absolute;
        top: -50px;
        right: -50px;
        width: 200px;
        height: 200px;
        background: linear-gradient(45deg, #0d6efd20, #0dcaf020);
        border-radius: 50%;
        z-index: 1;
        filter: blur(40px);
    }

    #digital-clock {
        font-family: 'JetBrains Mono', 'Consolas', monospace;
        font-weight: 800;
        font-size: clamp(2.5rem, 5vw, 5.5rem);
        color: #1f2937;
        line-height: 1;
        letter-spacing: -1px;
        text-shadow: 2px 2px 0px rgba(255,255,255,1);
        white-space: nowrap;
    }

    .day-progress-container {
        height: 6px;
        background: #e5e7eb;
        border-radius: 10px;
        overflow: hidden;
        margin-top: 1rem;
        width: 70%;
        margin-left: auto;
        margin-right: auto;
    }

    .day-progress-bar {
        height: 100%;
        background: linear-gradient(90deg, #3b82f6, #8b5cf6);
        width: 0%;
        transition: width 1s linear;
    }

    .nav-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        height: 100%;
    }

        .nav-grid .btn-wide {
            grid-column: span 2;
        }

    .nav-btn {
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        padding: 1.5rem 2rem;
        text-decoration: none;
        color: #1f2937;
        transition: all 0.2s ease;
    }

        .nav-btn:hover {
            transform: translateY(-5px);
            background: #ffffff;
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
        }

        .nav-btn h5 {
            font-weight: 700;
            font-size: 1.2rem;
            margin-bottom: 0.2rem;
            z-index: 2;
        }

        .nav-btn span {
            font-size: 0.9rem;
            color: #6b7280;
            z-index: 2;
        }

        .nav-btn i {
            position: absolute;
            bottom: -10px;
            right: 15px;
            font-size: 4rem;
            opacity: 0.1;
            transition: all 0.3s ease;
            z-index: 1;
            color: currentColor;
        }

        .nav-btn:hover i {
            transform: scale(1.1) rotate(-10deg);
            opacity: 0.2;
        }

        .nav-btn::after {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 6px;
        }

    .btn-schedule::after {
        background: #3b82f6;
    }

    .btn-schedule i {
        color: #3b82f6;
    }

    .btn-teachers::after {
        background: #06b6d4;
    }

    .btn-teachers i {
        color: #06b6d4;
    }

    .btn-groups::after {
        background: #10b981;
    }

    .btn-groups i {
        color: #10b981;
    }

    .btn-cabinets::after {
        background: #8b5cf6;
    }

    .btn-cabinets i {
        color: #8b5cf6;
    }

    .btn-subjects::after {
        background: #f59e0b;
    }

    .btn-subjects i {
        color: #f59e0b;
    }

    @@media (max-width: 991px) {
        .dashboard-wrapper {
            display: block;
            height: auto;
            overflow-y: auto;
            padding: 1rem;
        }

        .nav-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
            margin-top: 1.5rem;
        }

            .nav-grid .btn-wide {
                grid-column: span 1;
            }

        .nav-btn {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
            min-height: 80px;
            padding: 1rem 1.5rem;
        }

            .nav-btn i {
                position: static;
                font-size: 2rem;
                opacity: 1;
                margin-left: 1rem;
                transform: none;
            }

        #digital-clock {
            font-size: 3rem;
        }
    }
</style>

<div class="dashboard-wrapper">
    <div class="container h-100">
        <div class="row h-100 align-items-stretch">

            <div class="col-lg-5 mb-lg-0 h-100 pb-3 pb-lg-0">
                <div class="glass-card p-4 p-md-5 text-center">
                    <div class="info-card-content">
                        <h6 class="text-uppercase text-secondary fw-bold ls-1 mb-3">
                            @DateTime.Now.ToString("dd MMMM yyyy")
                        </h6>

                        <div class="d-inline-flex align-items-center justify-content-center mb-4 bg-white rounded-pill shadow-sm p-1 pe-3">
                            <span class="badge rounded-pill @badgeClass px-3 py-2 me-2">№ @weekNumber</span>
                            <span class="small fw-bold text-uppercase text-secondary">@weekType</span>
                        </div>

                        <div class="my-3">
                            <div id="digital-clock">@DateTime.Now.ToString("HH:mm:ss")</div>
                        </div>

                        <div class="day-progress-container mb-4" title="Прогресс дня">
                            <div id="day-progress" class="day-progress-bar"></div>
                        </div>

                        <div class="card border-0 bg-light bg-opacity-50 rounded-4 p-3 mt-2">
                            <div id="current-lesson" class="fw-medium text-dark">
                                <span class="spinner-border spinner-border-sm text-primary"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7 h-100">
                <div class="nav-grid">

                    <a asp-page="/Lessons/Index" class="nav-btn glass-card btn-schedule">
                        <div>
                            <h5>Расписание</h5>
                            <span>Просмотр и редактирование</span>
                        </div>
                        <i class="bi bi-calendar-event"></i>
                    </a>

                    <a asp-page="/Teatchers/Index" class="nav-btn glass-card btn-teachers">
                        <div>
                            <h5>Преподаватели</h5>
                            <span>Список сотрудников</span>
                        </div>
                        <i class="bi bi-person-video3"></i>
                    </a>

                    <a asp-page="/Groups/Index" class="nav-btn glass-card btn-groups">
                        <div>
                            <h5>Группы</h5>
                            <span>Студенческие списки</span>
                        </div>
                        <i class="bi bi-people"></i>
                    </a>

                    <a asp-page="/Cabinet/Index" class="nav-btn glass-card btn-cabinets">
                        <div>
                            <h5>Кабинеты</h5>
                            <span>Аудиторный фонд</span>
                        </div>
                        <i class="bi bi-door-open"></i>
                    </a>

                    <a asp-page="/Subjects/Index" class="nav-btn glass-card btn-subjects btn-wide">
                        <div>
                            <h5>Предметы и дисциплины</h5>
                            <span>Учебные планы</span>
                        </div>
                        <i class="bi bi-journal-bookmark"></i>
                    </a>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateDashboard() {
            const now = new Date();

            const timeString = now.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
            const clockEl = document.getElementById('digital-clock');
            if(clockEl) clockEl.textContent = timeString;

            const startDay = 8 * 60;
            const endDay = 18 * 60;
            const currentMin = now.getHours() * 60 + now.getMinutes();
            let percent = 0;
            if (currentMin > startDay) {
                percent = ((currentMin - startDay) / (endDay - startDay)) * 100;
            }
            if (percent > 100) percent = 100;
            if (percent < 0) percent = 0;
            document.getElementById('day-progress').style.width = `${percent}%`;

            const lessonBlock = document.getElementById('current-lesson');

            const lessons = [
                { id: 1, start: 9*60, end: 10*60+35, name: '1-я пара (09:00 - 10:35)' },
                { id: 2, start: 10*60+50, end: 12*60+25, name: '2-я пара (10:50 - 12:25)' },
                { id: 3, start: 12*60+45, end: 14*60+20, name: '3-я пара (12:45 - 14:20)' },
                { id: 4, start: 14*60+30, end: 16*60+05, name: '4-я пара (14:30 - 16:05)' },
                { id: 5, start: 16*60+10, end: 17*60+45, name: '5-я пара (16:10 - 17:45)' }
            ];

            let message = "";
            let found = false;

            for (let i = 0; i < lessons.length; i++) {
                const l = lessons[i];
                if (currentMin >= l.start && currentMin <= l.end) {
                    const left = l.end - currentMin;
                    message = `<div class="text-primary fw-bold">Идет ${l.name}</div>
                               <small class="text-muted">До конца ${left} мин</small>`;
                    found = true;
                    break;
                }
                if (currentMin < l.start) {
                    const wait = l.start - currentMin;
                    message = `<div class="text-dark fw-bold">Перерыв</div>
                               <small class="text-muted">Далее: ${l.name} через ${wait} мин</small>`;
                    found = true;
                    break;
                }
            }

            if (!found) {
                if (currentMin > lessons[lessons.length-1].end)
                    message = `<span class="text-success fw-bold">Учебный день окончен 🎉</span>`;
                else
                    message = `<span class="text-secondary">Доброе утро ☕</span>`;
            }

            if(lessonBlock) lessonBlock.innerHTML = message;
        }

        setInterval(updateDashboard, 1000);
        updateDashboard();
    </script>
}