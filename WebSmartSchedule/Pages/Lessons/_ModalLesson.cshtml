<div id="createLessonModal" class="modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <span class="btn-close" onclick="closeModal('createLessonModal')"></span>
            <form method="post" asp-page-handler="CreateLesson" class="needs-validation" novalidate>
                <h5 class="mb-3">Добавить занятие</h5>
                <input type="hidden" name="GroupId" value="@Model.SelectedGroupId" />

                <div class="mb-3">
                    <label class="form-label">Предмет</label>
                    <select name="SubjectId" class="form-select" required title="Выберите предмет из списка">
                        @foreach (var item in Model.Subjects)
                        {
                            <option value="@item.Id">@item.Title</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Преподаватель</label>
                    <select name="TeacherId" class="form-select" required title="Выберите преподавателя">
                        @foreach (var item in Model.Teachers)
                        {
                            <option value="@item.Id">@item.FullName</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Кабинет</label>
                    <select name="CabinetId" class="form-select" required title="Выберите аудиторию">
                        @foreach (var item in Model.Cabinets)
                        {
                            <option value="@item.Id">@item.number@(string.IsNullOrEmpty(item.BuildingName) ? "" : $" ({item.BuildingName})")</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Подгруппа</label>
                    <select name="Subgroup" class="form-select">
                        <option value="">Вся группа (без деления)</option>
                        <option value="1">1 подгруппа</option>
                        <option value="2">2 подгруппа</option>
                        <option value="3">3 подгруппа</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Временной слот</label>
                    <select name="TimeSlotId" class="form-select" required title="Выберите время занятия">
                        <option value="">-- Выберите Пару --</option>
                        @foreach (var item in Model.TimeSlots)
                        {
                            <option value="@item.Id">@item.SlotNumber</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Тип недели</label>
                    <select name="WeekTypeId" class="form-select" required title="Укажите периодичность">
                        @foreach (var item in Model.WeekTypes)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">День недели</label>
                    <select name="DayOfWeekId" class="form-select" required title="Выберите день недели">
                        <option value="1">Понедельник</option>
                        <option value="2">Вторник</option>
                        <option value="3">Среда</option>
                        <option value="4">Четверг</option>
                        <option value="5">Пятница</option>
                        <option value="6">Суббота</option>
                    </select>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeModal('createLessonModal')">Отмена</button>
                    <button type="submit" class="btn btn-primary">Добавить</button>
                </div>
            </form>
        </div>
    </div>
</div>

