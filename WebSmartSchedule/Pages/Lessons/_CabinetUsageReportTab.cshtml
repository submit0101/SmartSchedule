@model WebSmartSchedule.Pages.Lessons.IndexModel

<style>
    /* Базовые стили */
    .container-fluid {
        overflow-x: hidden;
    }

    .table-scroll-wrapper {
        max-height: 70vh;
        overflow-y: auto;
    }

        .table-scroll-wrapper thead th {
            position: sticky;
            top: 0;
            background-color: #F7F7F9;
            z-index: 2;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }

    @@media (min-width: 992px) {
        .table-scroll-wrapper

    {
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .table-scroll-wrapper::-webkit-scrollbar {
        display: none;
    }

    }

    .mobile-scroll-wrapper {
        height: calc(100vh - 420px);
        min-height: 300px;
        overflow-y: auto;
        scrollbar-width: thin;
        -webkit-overflow-scrolling: touch;
        padding-bottom: 100px !important;
    }

    .sticky-stats-card {
        position: sticky;
        top: 20px;
        transition: all 0.3s ease;
    }

    /* Стили для плавающего виджета */
    .floating-chart-widget {
        position: fixed;
        bottom: 20px;
        right: 20px;
        width: 320px;
        z-index: 990;
        display: none;
        box-shadow: 0 4px 25px rgba(0,0,0,0.2);
        border-radius: 16px;
        background: white;
        border: 1px solid rgba(0,0,0,0.05);
        animation: slideInUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@keyframes slideInUp {
        from

    {
        transform: translateY(50px);
        opacity: 0;
    }

    to {
        transform: translateY(0);
        opacity: 1;
    }

    }

    .mobile-card {
        background: white;
        border-radius: 12px;
        padding: 12px;
        margin-bottom: 8px;
        border: 1px solid #e0e0e0;
    }

    /* Стили для группы кнопок на графике */
    .chart-actions .btn {
        width: 32px;
        height: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
    }
</style>

<div class="container-fluid px-0">

    <div class="material-card mb-4">
        <h5 class="mb-3" style="color: var(--md-sys-color-primary); font-weight: 600;">Загруженность аудиторий</h5>
        <form id="cabFilterForm" class="row g-3 align-items-end" onsubmit="return false;">
            <div class="col-md-3">
                <label class="form-label text-muted small text-uppercase fw-bold">Здание</label>
                <select id="cabBuildingFilter" class="form-select">
                    <option value="">Все</option>
                    <option value="1">Новый корпус</option>
                    <option value="2">Старый корпус</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted small text-uppercase fw-bold">Тип недели</label>
                <select id="cabWeekTypeFilter" class="form-select">
                    <option value="">Все</option>
                    <option value="1">Числитель</option>
                    <option value="2">Знаменатель</option>
                    <option value="3">Обе</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted small text-uppercase fw-bold">День недели</label>
                <select id="cabDayFilter" class="form-select">
                    <option value="">Все</option>
                    <option value="1">Понедельник</option>
                    <option value="2">Вторник</option>
                    <option value="3">Среда</option>
                    <option value="4">Четверг</option>
                    <option value="5">Пятница</option>
                    <option value="6">Суббота</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="button" id="ShowCabUsageBtn" class="btn btn-primary w-100">
                    Сформировать отчет
                </button>
            </div>
        </form>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="material-card p-0 overflow-hidden h-100">
                <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-white flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-2">
                        <span class="fw-bold fs-5 text-dark">Результаты</span>
                        <span id="CabRecordsCount" class="badge bg-light text-dark border">0</span>
                    </div>

                    <div class="d-flex gap-2">
                        <button id="ExportCabExcelBtn" class="btn btn-sm btn-outline-success d-none align-items-center gap-2 px-3 rounded-pill">
                            <i class="bi bi-file-earmark-spreadsheet-fill"></i>
                            <span class="d-none d-sm-inline fw-medium">Excel</span>
                        </button>
                    </div>
                </div>

                <div class="d-none d-md-block table-scroll-wrapper">
                    <table class="table table-hover mb-0 align-middle">
                        <thead>
                            <tr>
                                <th class="ps-4">Аудитория</th>
                                <th class="text-center">Корпус</th>
                                <th class="text-center">Занятий</th>
                                <th class="text-center pe-4">Загрузка</th>
                            </tr>
                        </thead>
                        <tbody id="CabUsageData">
                            <tr><td colspan="4" class="text-center text-muted py-5">Выберите параметры</td></tr>
                        </tbody>
                    </table>
                </div>

                <div class="d-md-none p-3 bg-light mobile-scroll-wrapper" id="CabMobileContainer">
                    <div class="text-center text-muted py-4">Нет данных</div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 d-none d-lg-block">
            <div class="material-card sticky-stats-card">
                <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
                    <h6 class="m-0 fw-bold text-primary"><i class="bi bi-pie-chart-fill me-2"></i>Топ-5 Аудиторий</h6>

                    <div class="d-flex gap-2 chart-actions">
                        <button class="btn btn-light text-primary border shadow-sm" onclick="shareCabChart('desktop')" title="Поделиться в ВК">
                            <i class="bi bi-share-fill"></i>
                        </button>
                        <button class="btn btn-light text-muted border shadow-sm" onclick="downloadCabChartPng('desktop')" title="Скачать PNG">
                            <i class="bi bi-camera-fill"></i>
                        </button>
                    </div>

                </div>
                <div class="p-4 position-relative" style="height: 300px;">
                    <canvas id="DesktopCabPieChart"></canvas>
                </div>
                <div class="p-3 bg-light border-top rounded-bottom">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted small text-uppercase fw-bold">Средняя загр.</span>
                        <span id="DesktopCabAvg" class="fs-5 fw-bold text-dark">0%</span>
                    </div>
                    <div class="progress mt-2" style="height: 6px;">
                        <div id="DesktopCabAvgBar" class="progress-bar" role="progressbar" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="floatingCabWidget" class="floating-chart-widget d-lg-none">
    <div class="d-flex justify-content-between align-items-center p-3 border-bottom bg-white">
        <span class="fw-bold small text-uppercase text-primary">Топ-5</span>

        <div class="d-flex align-items-center gap-2">
            <div class="d-flex gap-2 chart-actions">
                <button class="btn btn-white text-primary border shadow-sm" onclick="shareCabChart('mobile')">
                    <i class="bi bi-share-fill"></i>
                </button>
                <button class="btn btn-white text-secondary border shadow-sm" onclick="downloadCabChartPng('mobile')">
                    <i class="bi bi-camera-fill"></i>
                </button>
            </div>

            <div style="width: 1px; height: 24px; background: #eee; margin: 0 4px;"></div>
            <button type="button" class="btn-close" onclick="closeCabWidget()"></button>
        </div>
    </div>
    <div class="p-3 text-center bg-white">
        <div style="height: 250px; position: relative;">
            <canvas id="floatingCabPieChart"></canvas>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/exceljs/dist/exceljs.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/file-saver/dist/FileSaver.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<script>
    (function () {
        let cabReportData = [];
        let desktopCabChart = null;
        let mobileCabChart = null;
        let currentAvg = "0%";

        document.getElementById("ShowCabUsageBtn").addEventListener("click", async () => {
            const build = document.getElementById("cabBuildingFilter").value;
            const week = document.getElementById("cabWeekTypeFilter").value;
            const day = document.getElementById("cabDayFilter").value;
            const btn = document.getElementById("ShowCabUsageBtn");

            btn.style.width = `${btn.offsetWidth}px`;
            const originalText = btn.innerHTML;

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>...';

            setTimeout(async () => {
                try {
                    const url = `http://localhost:5062/api/Lesson/cabinet-usage?buildingId=${build}&weekTypeId=${week}&dayOfWeekId=${day}`;
                    const res = await fetch(url);
                    if (!res.ok) throw new Error("Server Error");

                    const data = await res.json();
                    cabReportData = data;

                    renderCabResults(data);

                    if (data && data.length > 0) {
                        requestAnimationFrame(() => {
                            updateCabCharts(data);
                            document.getElementById("ExportCabExcelBtn").classList.remove("d-none");
                            document.getElementById("ExportCabExcelBtn").classList.add("d-flex");

                            // Показываем кнопку ВК если есть данные
                            if (window.innerWidth < 992) document.getElementById('floatingCabWidget').style.display = 'block';
                        });
                    } else {
                        closeCabWidget();
                        document.getElementById("ExportCabExcelBtn").classList.add("d-none");
                    }
                } catch (err) {
                    console.error(err);
                    alert("Ошибка загрузки данных");
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                    btn.style.width = '';
                }
            }, 0);
        });

        // --- ГЛАВНАЯ МАГИЯ: ПОДЕЛИТЬСЯ ФОТО ---
        window.shareCabChart = function(type) {
            const chart = type === 'mobile' ? mobileCabChart : desktopCabChart;
            if (!chart) return alert("График не найден");

            // 1. Превращаем график в файл (Blob)
            chart.canvas.toBlob(async (blob) => {
                if (!blob) return;

                const file = new File([blob], "chart.png", { type: "image/png" });

                // 2. Пробуем "Нативный шеринг" (Работает на Телефонах)
                if (navigator.canShare && navigator.canShare({ files: [file] })) {
                    try {
                        await navigator.share({
                            files: [file],
                            title: 'Статистика аудиторий',
                            text: `Загрузка аудиторий: ${currentAvg}`,
                        });
                    } catch (error) {
                        console.log('Отменено пользователем'); // Не ругаемся, если просто закрыл окно
                    }
                }
                // 3. Если это Компьютер (Desktop)
                else {
                    try {
                        // Пытаемся скопировать картинку в буфер обмена
                        // Это работает в Chrome/Edge/Yandex на ПК
                        await navigator.clipboard.write([
                            new ClipboardItem({
                                "image/png": blob
                            })
                        ]);

                        // Открываем ВК в новой вкладке
                        window.open('https://vk.com/share.php?comment=' + encodeURIComponent(`Средняя загрузка аудиторий: ${currentAvg}`), '_blank');

                        // Сообщаем пользователю
                        alert("📷 Диаграмма скопирована!\n\nПросто нажмите Ctrl+V (Вставить) в открывшемся окне ВК.");

                    } catch (err) {
                        // Если браузер совсем старый и не умеет копировать картинки
                        // Скачиваем файл по старинке
                        saveAs(blob, "chart_stats.png");
                        alert("Файл скачан. Загрузите его в ВК вручную.");
                        window.open('https://vk.com/', '_blank');
                    }
                }
            }, 'image/png');
        };
        // ----------------------------------------

        function renderCabResults(data) {
            const tbody = document.getElementById("CabUsageData");
            const mobile = document.getElementById("CabMobileContainer");
            const count = document.getElementById("CabRecordsCount");

            tbody.innerHTML = "";
            mobile.innerHTML = "";

            if (!data || data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="4" class="text-center text-muted py-5">Нет данных</td></tr>`;
                mobile.innerHTML = `<div class="text-center text-muted py-4">Нет данных</div>`;
                count.innerText = "0";
                updateCabStats(0);
                return;
            }

            count.innerText = data.length;
            let sumPct = 0;
            let tableRows = "";
            let mobileCards = "";

            data.forEach(item => {
                sumPct += item.usagePercentage;
                const percent = item.usagePercentage.toFixed(1);

                const colorClass = percent > 70 ? "text-success" : percent > 40 ? "text-warning" : "text-danger";
                const bgClass = percent > 70 ? "bg-success" : percent > 40 ? "bg-warning" : "bg-danger";
                const borderClass = percent > 70 ? "border-success" : percent > 40 ? "border-warning" : "border-danger";

                tableRows += `
                    <tr>
                        <td class="ps-4 fw-bold text-dark">${item.cabinetNumber}</td>
                        <td class="text-center text-muted">${item.buildingName}</td>
                        <td class="text-center font-monospace">${item.totalLessons}</td>
                        <td class="text-center">
                            <span class="badge ${bgClass} bg-opacity-10 ${colorClass} border ${borderClass} rounded-pill px-3">${percent}%</span>
                        </td>
                    </tr>`;

                mobileCards += `
                    <div class="mobile-card shadow-sm">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <span class="fw-bold text-dark">Ауд. ${item.cabinetNumber}</span>
                                <small class="text-muted d-block" style="font-size:0.75rem">${item.buildingName}</small>
                            </div>
                            <span class="fw-bold ${colorClass}">${percent}%</span>
                        </div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar ${bgClass}" style="width: ${percent}%"></div>
                        </div>
                        <div class="mt-2 text-end small text-muted">
                            Занятий: ${item.totalLessons}
                        </div>
                    </div>`;
            });

            tbody.innerHTML = tableRows;
            mobile.innerHTML = mobileCards;

            const avg = data.length > 0 ? (sumPct / data.length).toFixed(1) : 0;
            currentAvg = `${avg}%`;
            updateCabStats(avg);
        }

        function updateCabStats(avg) {
            document.getElementById("DesktopCabAvg").innerText = `${avg}%`;
            const bar = document.getElementById("DesktopCabAvgBar");
            if (bar) {
                bar.style.width = `${avg}%`;
                bar.className = `progress-bar ${avg > 70 ? 'bg-success' : avg > 40 ? 'bg-warning' : 'bg-primary'}`;
            }
        }

        function updateCabCharts(data) {
            const sorted = [...data].sort((a, b) => b.usagePercentage - a.usagePercentage);
            const top5 = sorted.slice(0, 5);
            const labels = top5.map(d => `${d.cabinetNumber} (${d.usagePercentage.toFixed(0)}%)`);
            const values = top5.map(d => d.usagePercentage);
            const bgColors = ['#EF5350', '#42A5F5', '#66BB6A', '#FFA726', '#AB47BC'];

            const config = {
                type: 'doughnut',
                data: { labels: labels, datasets: [{ data: values, backgroundColor: bgColors, borderWidth: 2, borderColor: '#ffffff' }] },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom', labels: { boxWidth: 12, padding: 20, font: {size: 11} } },
                        tooltip: { enabled: false }
                    },
                    cutout: '65%',
                    layout: { padding: 10 }
                }
            };

            const deskCanvas = document.getElementById('DesktopCabPieChart');
            if (Chart.getChart(deskCanvas)) Chart.getChart(deskCanvas).destroy();
            desktopCabChart = new Chart(deskCanvas, config);

            const mobCanvas = document.getElementById('floatingCabPieChart');
            if (Chart.getChart(mobCanvas)) Chart.getChart(mobCanvas).destroy();

            const mobConfig = JSON.parse(JSON.stringify(config));
            mobConfig.options.plugins.legend.position = 'bottom';
            mobConfig.options.plugins.legend.labels.boxWidth = 10;
            mobConfig.options.layout.padding = 5;

            mobileCabChart = new Chart(mobCanvas, mobConfig);
        }

        window.downloadCabChartPng = function(type) {
            const chart = type === 'mobile' ? mobileCabChart : desktopCabChart;
            if (!chart) return alert("Нет графика");
            const a = document.createElement('a');
            a.href = chart.toBase64Image();
            a.download = `Cabinet_Chart_${type}.png`;
            a.click();
        };

        window.closeCabWidget = function() {
            document.getElementById('floatingCabWidget').style.display = 'none';
        };

        document.getElementById("ExportCabExcelBtn").addEventListener("click", async () => {
            if (!cabReportData.length) return;
            const workbook = new ExcelJS.Workbook();
            const sheet = workbook.addWorksheet('Аудитории');
            // ... (Код экспорта Excel остался прежним)
            // Для краткости не дублирую длинный кусок Excel, он работает как надо

             const borderStyle = { top: { style: 'thin' }, left: { style: 'thin' }, bottom: { style: 'thin' }, right: { style: 'thin' } };
            const headerFill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FF4472C4' } };
            const headerFont = { bold: true, color: { argb: 'FFFFFFFF' } };

            sheet.mergeCells('A1:D1');
            sheet.getCell('A1').value = 'ОТЧЕТ: АУДИТОРИИ';
            sheet.getCell('A1').font = { size: 14, bold: true };
            sheet.getCell('A1').alignment = { horizontal: 'center' };

            sheet.getRow(3).values = ['Аудитория', 'Корпус', 'Занятий', 'Загрузка %'];
            sheet.columns = [{ width: 15 }, { width: 25 }, { width: 15 }, { width: 15 }];

            const headerRow = sheet.getRow(3);
            headerRow.eachCell(c => { c.fill = headerFill; c.font = headerFont; c.alignment = { horizontal: 'center' }; c.border = borderStyle; });

            cabReportData.forEach((d, i) => {
                const r = sheet.getRow(4 + i);
                const pct = d.usagePercentage / 100;
                r.values = [d.cabinetNumber, d.buildingName, d.totalLessons, pct];
                r.getCell(4).numFmt = '0.0%';
                r.eachCell(c => { c.border = borderStyle; c.alignment = { horizontal: 'center' }; });
                if (d.usagePercentage > 70) r.getCell(4).font = { color: { argb: 'FF009900' }, bold: true };
            });

            const buffer = await workbook.xlsx.writeBuffer();
            saveAs(new Blob([buffer]), `Cabinets_Report_${new Date().toISOString().slice(0, 10)}.xlsx`);
        });
    })();
</script>