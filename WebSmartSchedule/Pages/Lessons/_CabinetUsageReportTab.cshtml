@model WebSmartSchedule.Pages.Lessons.IndexModel

<style>
    /* Стили таблицы и прокрутки */
    .table-scroll-wrapper {
        max-height: 70vh;
        overflow-y: auto;
        position: relative;
    }

        .table-scroll-wrapper thead th {
            position: sticky;
            top: 0;
            background-color: #f8f9fa;
            z-index: 20;
            box-shadow: 0 1px 2px rgba(0,0,0,0.1);
        }

    /* Стили группировки */
    .group-divider-row {
        background-color: #f1f3f5 !important;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .group-divider-text {
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        color: #495057;
        padding: 10px 20px !important;
    }

    .group-divider-row.collapsed i.bi-chevron-down {
        transform: rotate(-90deg);
    }

    /* Адаптивность диаграмм */
    .chart-container {
        position: relative;
        height: 250px;
        width: 100%;
    }

    /* Мобильная версия */
    .mobile-stats-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #dee2e6;
        margin-bottom: 20px;
    }

    .mobile-card {
        background: white;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 10px;
        border: 1px solid #dee2e6;
    }

    /* Кнопка сворачивания диаграммы */
    .btn-toggle-chart {
        padding: 0;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        border: 1px solid #eee;
        background: #f8f9fa;
        transition: all 0.3s;
    }

        .btn-toggle-chart[aria-expanded="false"] {
            transform: rotate(180deg);
        }
</style>

<div class="container-fluid px-0">
    <!-- Фильтры -->
    <div class="material-card mb-4 shadow-sm border-0">
        <h5 class="mb-3 fw-bold text-primary">Загруженность аудиторий</h5>
        <form id="cabFilterForm" class="row g-3 align-items-end" onsubmit="return false;">
            <div class="col-6 col-md-2">
                <label class="form-label small fw-bold text-muted text-uppercase">Здание</label>
                <select id="cabBuildingFilter" class="form-select shadow-none">
                    <option value="">Все здания</option>
                    <option value="1">Новый корпус</option>
                    <option value="2">Старый корпус</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small fw-bold text-muted text-uppercase">Тип недели</label>
                <select id="cabWeekTypeFilter" class="form-select shadow-none">
                    <option value="">Все недели</option>
                    <option value="1">Числитель</option>
                    <option value="2">Знаменатель</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small fw-bold text-muted text-uppercase">День</label>
                <select id="cabDayFilter" class="form-select shadow-none">
                    <option value="">Любой день</option>
                    <option value="1">Пн</option>
                    <option value="2">Вт</option>
                    <option value="3">Ср</option>
                    <option value="4">Чт</option>
                    <option value="5">Пт</option>
                    <option value="6">Сб</option>
                </select>
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label small fw-bold text-primary text-uppercase">Группировка</label>
                <select id="cabGroupBy" class="form-select border-primary shadow-none">
                    <option value="none">Без группировки</option>
                    <option value="building">По корпусам</option>
                    <option value="usage">По уровню загрузки</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="button" id="ShowCabUsageBtn" class="btn btn-primary w-100 fw-bold shadow-sm">
                    <i class="bi bi-play-fill me-1"></i> Сформировать
                </button>
            </div>
        </form>
    </div>

    <div class="row g-4">
        <!-- Контент -->
        <div class="col-lg-8">
            <div class="material-card p-0 overflow-hidden shadow-sm border-0 bg-white">
                <!-- Панель управления результатами -->
                <div class="p-3 border-bottom d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span class="fw-bold">Найдено: <span id="CabRecordsCount" class="text-primary border bg-light px-2 rounded">0</span></span>

                    <div class="flex-grow-1 mx-md-3" style="min-width: 200px;">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                            <input type="text" id="cabTableSearch" class="form-control border-start-0 shadow-none" placeholder="Поиск номера аудитории...">
                        </div>
                    </div>

                    <!-- ВОТ ОН, EXCEL! -->
                    <button id="ExportCabExcelBtn" class="btn btn-sm btn-outline-success d-none rounded-pill px-3 fw-bold">
                        <i class="bi bi-file-earmark-spreadsheet me-1"></i> Excel
                    </button>
                </div>

                <!-- Мобильная диаграмма (сворачиваемая) -->
                <div class="d-md-none p-3 bg-light border-bottom" id="MobileChartBlock" style="display:none;">
                    <div class="mobile-stats-card shadow-sm overflow-hidden">
                        <div class="p-3 d-flex justify-content-between align-items-center bg-white border-bottom">
                            <h6 class="m-0 fw-bold small text-muted text-uppercase">Топ-5 Загрузки</h6>
                            <button class="btn btn-toggle-chart" type="button" data-bs-toggle="collapse" data-bs-target="#mobileChartCollapse">
                                <i class="bi bi-chevron-up"></i>
                            </button>
                        </div>
                        <div class="collapse show" id="mobileChartCollapse">
                            <div class="p-3 bg-white">
                                <div class="chart-container">
                                    <canvas id="MobileCabPieChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Таблица (Desktop) -->
                <div class="d-none d-md-block table-scroll-wrapper">
                    <table class="table table-hover mb-0 align-middle">
                        <thead>
                            <tr>
                                <th class="ps-4">Аудитория</th>
                                <th class="text-center cab-col-building">Корпус</th>
                                <th class="text-center">Занятий</th>
                                <th class="text-center pe-4">Загрузка</th>
                            </tr>
                        </thead>
                        <tbody id="CabUsageData">
                            <tr><td colspan="4" class="text-center text-muted py-5">Настройте фильтры и нажмите "Сформировать"</td></tr>
                        </tbody>
                    </table>
                </div>

                <!-- Карточки (Mobile) -->
                <div class="d-md-none p-3 bg-light mobile-scroll-wrapper" id="CabMobileContainer">
                </div>
            </div>
        </div>

        <!-- Боковая панель (Desktop) -->
        <div class="col-lg-4 d-none d-lg-block">
            <div class="material-card sticky-stats-card p-3 shadow-sm border-0">
                <h6 class="fw-bold text-primary mb-3">Эффективность использования</h6>
                <div class="chart-container" style="height: 280px;">
                    <canvas id="DesktopCabPieChart"></canvas>
                </div>
                <div class="mt-4 p-3 bg-light rounded-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="small fw-bold text-muted text-uppercase">Средняя загрузка</span>
                        <span id="DesktopCabAvg" class="fw-bold">0%</span>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div id="DesktopCabAvgBar" class="progress-bar progress-bar-striped progress-bar-animated" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- БИБЛИОТЕКИ ДЛЯ EXCEL -->
<script src="https://cdn.jsdelivr.net/npm/exceljs/dist/exceljs.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/file-saver/dist/FileSaver.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<script>
    (function () {
        let cabReportData = [];
        let charts = { desktop: null, mobile: null };

        // 1. ПОЛУЧЕНИЕ ДАННЫХ
        document.getElementById("ShowCabUsageBtn").addEventListener("click", async () => {
            const b = document.getElementById("cabBuildingFilter").value;
            const w = document.getElementById("cabWeekTypeFilter").value;
            const d = document.getElementById("cabDayFilter").value;
            const btn = document.getElementById("ShowCabUsageBtn");

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Загрузка...';

            try {
                // ПАРАМЕТР dayOfWeekId ВЕРНУЛСЯ![cite: 1]
                const url = `http://localhost:5062/api/report/cabinet-usage?buildingId=${b}&weekTypeId=${w}&dayOfWeekId=${d}`;
                const res = await fetch(url);
                cabReportData = await res.json();

                renderCabResults(cabReportData);
                updateCharts(cabReportData);

                document.getElementById("ExportCabExcelBtn").classList.toggle("d-none", cabReportData.length === 0);
                document.getElementById("MobileChartBlock").style.display = cabReportData.length > 0 ? "block" : "none";
            } catch (e) {
                alert("Ошибка загрузки данных");
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-play-fill me-1"></i> Сформировать';
            }
        });

        // 2. ГРУППИРОВКА И ПОИСК
        document.getElementById("cabGroupBy").addEventListener("change", () => renderCabResults(cabReportData));

        document.getElementById("cabTableSearch").addEventListener("input", (e) => {
            const val = e.target.value.toLowerCase();
            document.querySelectorAll(".cab-data-row, .cab-mobile-card").forEach(el => {
                el.style.display = el.innerText.toLowerCase().includes(val) ? "" : "none";
            });
            if(val) $(".group-divider-row").hide(); else $(".group-divider-row").show();
        });

        // 3. ОТРИСОВКА РЕЗУЛЬТАТОВ (С ГРУППИРОВКОЙ)
        function renderCabResults(data) {
            const tbody = document.getElementById("CabUsageData");
            const mobile = document.getElementById("CabMobileContainer");
            const groupBy = document.getElementById("cabGroupBy").value;

            tbody.innerHTML = ""; mobile.innerHTML = "";
            if (!data.length) return;

            let sorted = [...data];
            if (groupBy === "building") sorted.sort((a,b) => (a.buildingName||"").localeCompare(b.buildingName||""));
            else if (groupBy === "usage") sorted.sort((a,b) => b.usagePercentage - a.usagePercentage);

            document.querySelectorAll(".cab-col-building").forEach(el => el.style.display = groupBy === "building" ? "none" : "");

            let currentGroup = null, groupIdx = 0, sumPct = 0;

            sorted.forEach(item => {
                sumPct += item.usagePercentage;
                const pct = item.usagePercentage.toFixed(1);
                const color = pct > 70 ? "success" : pct > 40 ? "warning" : "danger";

                let groupVal = groupBy === "building" ? (item.buildingName || "Прочее") :
                               (pct > 70 ? "Высокая загрузка" : pct > 40 ? "Средняя загрузка" : "Низкая загрузка");

                if (groupBy !== "none" && groupVal !== currentGroup) {
                    currentGroup = groupVal; groupIdx++;
                    tbody.innerHTML += `<tr class="group-divider-row" data-id="${groupIdx}"><td colspan="4" class="group-divider-text fw-bold text-uppercase"><i class="bi bi-chevron-down me-2 text-primary"></i>${groupVal}</td></tr>`;
                    mobile.innerHTML += `<div class="fw-bold text-muted small text-uppercase mt-3 mb-2 ps-2 border-start border-primary border-3">${groupVal}</div>`;
                }

                const buildTd = groupBy === "building" ? "" : `<td class="text-center text-muted">${item.buildingName}</td>`;
                tbody.innerHTML += `
                    <tr class="cab-data-row" data-parent="${groupIdx}">
                        <td class="ps-4 fw-bold text-dark">${item.cabinetNumber}</td>
                        ${buildTd}
                        <td class="text-center font-monospace">${item.totalLessons}</td>
                        <td class="text-center pe-4"><span class="badge bg-${color} bg-opacity-10 text-${color} border border-${color} rounded-pill px-3">${pct}%</span></td>
                    </tr>`;

                mobile.innerHTML += `
                    <div class="mobile-card shadow-sm cab-mobile-card">
                        <div class="d-flex justify-content-between align-items-center mb-2"><span class="fw-bold">Ауд. ${item.cabinetNumber}</span><span class="badge bg-${color}">${pct}%</span></div>
                        <div class="progress" style="height: 6px;"><div class="progress-bar bg-${color}" style="width:${pct}%"></div></div>
                    </div>`;
            });

            $(".group-divider-row").click(function() {
                const id = $(this).data("id");
                $(this).toggleClass("collapsed");
                $(`.cab-data-row[data-parent="${id}"]`).fadeToggle(150);
            });

            document.getElementById("CabRecordsCount").innerText = data.length;
            const avg = (sumPct / data.length).toFixed(1);
            document.getElementById("DesktopCabAvg").innerText = avg + "%";
            const bar = document.getElementById("DesktopCabAvgBar");
            bar.style.width = avg + "%";
            bar.className = `progress-bar progress-bar-striped progress-bar-animated bg-${avg > 70 ? 'success' : avg > 40 ? 'warning' : 'primary'}`;
        }

        // 4. ДИАГРАММЫ
        function updateCharts(data) {
            const top = [...data].sort((a,b) => b.usagePercentage - a.usagePercentage).slice(0, 5);
            const chartData = {
                labels: top.map(d => "Ауд. " + d.cabinetNumber),
                datasets: [{ data: top.map(d => d.usagePercentage), backgroundColor: ['#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b'], borderWidth: 2, borderColor: '#fff' }]
            };
            const opt = { maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 11 }, usePointStyle: true } } }, cutout: '75%' };

            if (charts.desktop) charts.desktop.destroy();
            charts.desktop = new Chart(document.getElementById('DesktopCabPieChart'), { type: 'doughnut', data: chartData, options: opt });

            if (charts.mobile) charts.mobile.destroy();
            charts.mobile = new Chart(document.getElementById('MobileCabPieChart'), { type: 'doughnut', data: chartData, options: opt });
        }

        // 5. EXCEL ЭКСПОРТ (ВОССТАНОВЛЕНО)[cite: 1]
        document.getElementById("ExportCabExcelBtn").addEventListener("click", async () => {
            if (!cabReportData.length) return;

            const workbook = new ExcelJS.Workbook();
            const sheet = workbook.addWorksheet('Загрузка аудиторий');

            // Заголовок
            sheet.mergeCells('A1:D1');
            const mainTitle = sheet.getCell('A1');
            mainTitle.value = 'ОТЧЕТ ПО ЗАГРУЖЕННОСТИ АУДИТОРИЙ';
            mainTitle.font = { size: 14, bold: true, color: { argb: 'FFFFFFFF' } };
            mainTitle.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FF4E73DF' } };
            mainTitle.alignment = { horizontal: 'center' };

            // Шапка таблицы
            sheet.getRow(3).values = ['Аудитория', 'Корпус', 'Кол-во занятий', 'Процент загрузки'];
            sheet.getRow(3).font = { bold: true };
            sheet.columns = [{ width: 15 }, { width: 30 }, { width: 15 }, { width: 15 }];

            // Данные
            cabReportData.forEach((item, index) => {
                const row = sheet.addRow([
                    item.cabinetNumber,
                    item.buildingName,
                    item.totalLessons,
                    item.usagePercentage / 100
                ]);
                row.getCell(4).numFmt = '0.0%';

                // Раскраска процентов
                if (item.usagePercentage > 70) row.getCell(4).font = { color: { argb: 'FF00B050' }, bold: true };
                else if (item.usagePercentage < 30) row.getCell(4).font = { color: { argb: 'FFFF0000' } };
            });

            // Авто-границы
            sheet.eachRow((row, rowNumber) => {
                if (rowNumber >= 3) {
                    row.eachCell(cell => {
                        cell.border = { top: { style: 'thin' }, left: { style: 'thin' }, bottom: { style: 'thin' }, right: { style: 'thin' } };
                    });
                }
            });

            const buffer = await workbook.xlsx.writeBuffer();
            saveAs(new Blob([buffer]), `Cabinet_Usage_Report_${new Date().toLocaleDateString()}.xlsx`);
        });
    })();
</script>