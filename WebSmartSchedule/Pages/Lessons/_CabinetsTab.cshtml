@model WebSmartSchedule.Pages.Lessons.IndexModel

<div class="container mt-4">
    <h4 class="text-center">Найти свободные кабинеты</h4>

    <form id="cabinetSearchForm" class="d-flex flex-wrap align-items-end gap-3 mb-3">
        <div class="flex-grow-1 min-w-200">
            <label for="daySelect" class="form-label">День недели</label>
            <select id="daySelect" class="form-select">
                <option value="1">Понедельник</option>
                <option value="2">Вторник</option>
                <option value="3">Среда</option>
                <option value="4">Четверг</option>
                <option value="5">Пятница</option>
                <option value="6">Суббота</option>
            </select>
        </div>

        <div class="flex-grow-1 min-w-200">
            <label for="timeSlotSelect" class="form-label">Временной слот</label>
            <select id="timeSlotSelect" class="form-select">
                @foreach (var Time in Model.TimeSlots)
                {
                    <option value="@Time.Id">@Time.SlotNumber</option>
                }
            </select>
        </div>

        <div class="flex-grow-1 min-w-200">
            <label for="weekTypeSelect" class="form-label">Тип недели</label>
            <select id="weekTypeSelect" class="form-select">
                @foreach (var weekTy in Model.WeekTypes)
                {
                    <option value="@weekTy.Id">@weekTy.Name</option>
                }
            </select>
        </div>

        <div class="flex-grow-1 min-w-200">
            <label for="BuildingSelect" class="form-label">Корпус</label>
            <select id="BuildingSelect" class="form-select">
                <option value="">-- Все --</option>
                @foreach (var bulding in Model.Buildings)
                {
                    <option value="@bulding.Id">@bulding.Name</option>
                }
            </select>
        </div>

        <div>
            <button type="submit" class="btn btn-primary w-100">Найти</button>
        </div>

        <div>
            <button type="button" class="btn btn-success w-100" onclick="exportToExcel()">Excel</button>
        </div>
    </form>

    <div class="scroll-desktop d-none d-md-block">
        <table class="table table-hover table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>Номер</th>
                    <th>Корпус</th>
                    <th>Вместимость</th>
                    <th>Оборудование</th>
                </tr>
            </thead>
            <tbody id="freeCabinetsList">
                <tr><td colspan="4" class="text-center text-muted">Выберите параметры</td></tr>
            </tbody>
        </table>
    </div>

    <div class="scroll-mobile d-block d-md-none">
        <div id="freeCabinetsCards" class="d-flex flex-column gap-3">
            <div class="text-center text-muted">Выберите параметры</div>
        </div>
    </div>
</div>

<style>
    #freeCabinetsList td, #freeCabinetsList th {
        text-align: center;
        vertical-align: middle;
    }

    .card-animation {
        opacity: 0;
        transform: translateY(20px);
        animation: fadeInUp .4s forwards;
    }

    @@keyframes fadeInUp {
        to

    {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .scroll-desktop {
        max-height: 450px;
        overflow-y: auto;
        border-radius: 8px;
        padding-right: 5px;
    }

    .scroll-mobile {
        max-height: 450px;
        overflow-y: auto;
        padding-right: 5px;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/exceljs/dist/exceljs.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/file-saver"></script>

<script>
    let freeCabinetsData = [];

    document.getElementById("cabinetSearchForm").addEventListener("submit", async function (e) {
        e.preventDefault();
        const day = daySelect.value;
        const timeSlot = timeSlotSelect.value;
        const weekType = weekTypeSelect.value;
        const buildingId = BuildingSelect.value;

        const response = await fetch(`http://localhost:5062/api/lesson/available?day=${day}&timeslot=${timeSlot}&weektype=${weekType}&buildingId=${buildingId}`);
        if (!response.ok) return;

        freeCabinetsData = await response.json();
        updateCabinetsUI(freeCabinetsData);
    });

    function updateCabinetsUI(data) {
        const tbody = freeCabinetsList;
        const cards = freeCabinetsCards;

        tbody.innerHTML = "";
        cards.innerHTML = "";

        if (data.length === 0) {
            tbody.innerHTML = `<tr><td colspan="4" class="text-center text-muted">Нет доступных кабинетов</td></tr>`;
            cards.innerHTML = `<div class="text-center text-muted">Нет доступных кабинетов</div>`;
            return;
        }

        data.forEach(c => {
            const row = document.createElement("tr");
            row.innerHTML = `
                <td>${c.number}</td>
                <td>${c.buldingName || '—'}</td>
                <td>${c.capacity}</td>
                <td>${c.equipment || '—'}</td>`;
            tbody.appendChild(row);
        });

        data.forEach((c, i) => {
            const card = document.createElement("div");
            card.className = "card shadow-sm p-3 card-animation";
            card.style.animationDelay = `${i * 0.07}s`;
            card.innerHTML = `
                <h6 class="mb-2">Кабинет ${c.number}</h6>
                <p class="mb-1"><strong>Корпус:</strong> ${c.buldingName || '—'}</p>
                <p class="mb-1"><strong>Вместимость:</strong> ${c.capacity}</p>
                <p class="mb-0"><strong>Оборудование:</strong> ${c.equipment || '—'}</p>`;
            cards.appendChild(card);
        });
    }

        async function exportToExcel() {
        if (!freeCabinetsData || freeCabinetsData.length === 0) return;

        const wb = new ExcelJS.Workbook();
        const sheet = wb.addWorksheet("Свободные кабинеты");

        sheet.views = [{ state: "frozen", ySplit: 6 }];

        const bigTitle = "Отчёт о свободных кабинетах";
        const dayText = daySelect.options[daySelect.selectedIndex].text;
        const timeSlotText = timeSlotSelect.options[timeSlotSelect.selectedIndex].text;
        const weekTypeText = weekTypeSelect.options[weekTypeSelect.selectedIndex].text;
        const buildingText = BuildingSelect.options[BuildingSelect.selectedIndex].text;
        const total = freeCabinetsData.length;

        sheet.mergeCells("A1:D1");
        sheet.getCell("A1").value = bigTitle;
        sheet.getCell("A1").font = { name: "Arial", size: 18, bold: true };
        sheet.getCell("A1").alignment = { horizontal: "center" };

        sheet.mergeCells("A2:D2");
        sheet.getCell("A2").value = `День: ${dayText}`;
        sheet.getCell("A2").font = { name: "Arial", size: 13 };
        sheet.getCell("A2").alignment = { horizontal: "center" };

        sheet.mergeCells("A3:D3");
        sheet.getCell("A3").value = `Временной слот: ${timeSlotText}`;
        sheet.getCell("A3").font = { name: "Arial", size: 13 };
        sheet.getCell("A3").alignment = { horizontal: "center" };

        sheet.mergeCells("A4:D4");
        sheet.getCell("A4").value = `Тип недели: ${weekTypeText}`;
        sheet.getCell("A4").font = { name: "Arial", size: 13 };
        sheet.getCell("A4").alignment = { horizontal: "center" };

        sheet.mergeCells("A5:D5");
        sheet.getCell("A5").value = `Корпус: ${buildingText}`;
        sheet.getCell("A5").font = { name: "Arial", size: 13 };
        sheet.getCell("A5").alignment = { horizontal: "center" };

        sheet.mergeCells("A6:D6");
        sheet.getCell("A6").value = `Количество свободных кабинетов: ${total}`;
        sheet.getCell("A6").font = { name: "Arial", size: 13, bold: true };
        sheet.getCell("A6").alignment = { horizontal: "center" };

        sheet.addRow([]);

        sheet.addRow(["Номер", "Корпус", "Вместимость", "Оборудование"]);

        const headerRow = sheet.getRow(sheet.lastRow.number);

        headerRow.eachCell(cell => {
            cell.font = { name: "Arial", bold: true, color: { argb: "FFFFFFFF" } };
            cell.fill = { type: "pattern", pattern: "solid", fgColor: { argb: "4472C4" } };
            cell.alignment = { horizontal: "center", vertical: "middle" };
            cell.border = {
                top: { style: "thin" },
                left: { style: "thin" },
                bottom: { style: "thin" },
                right: { style: "thin" }
            };
        });

        freeCabinetsData.forEach((c, index) => {
            const row = sheet.addRow([
                c.number,
                c.buldingName || "—",
                c.capacity,
                c.equipment || "—"
            ]);

            row.eachCell((cell) => {
                cell.font = { name: "Arial", size: 12 };
                cell.alignment = { horizontal: "center", vertical: "middle", wrapText: true };
                cell.border = {
                    top: { style: "thin" },
                    left: { style: "thin" },
                    bottom: { style: "thin" },
                    right: { style: "thin" }
                };
            });

            if (index % 2 === 0) {
                row.eachCell(cell => {
                    cell.fill = { type: "pattern", pattern: "solid", fgColor: { argb: "F2F2F2" } };
                });
            }
        });

        sheet.columns.forEach(col => {
            let maxLength = 0;
            col.eachCell({ includeEmpty: true }, cell => {
                const v = cell.value ? cell.value.toString() : "";
                maxLength = Math.max(maxLength, v.length);
            });
            col.width = maxLength + 5;
        });

        const buffer = await wb.xlsx.writeBuffer();
        saveAs(new Blob([buffer]), "Свободные_кабинеты.xlsx");
    }
 
</script>
