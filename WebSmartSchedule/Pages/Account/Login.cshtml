@page
@model WebSmartSchedule.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Вход в систему";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0">Авторизация</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label">Логин</label>
                            <input asp-for="Input.Username" class="form-control" placeholder="Введите логин" />
                            <span asp-validation-for="Input.Username" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Пароль</label>
                            <input asp-for="Input.Password" type="password" class="form-control" placeholder="******" />
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 mt-2">Войти</button>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <span class="text-muted small">Нет аккаунта? <a asp-page="./Register">Зарегистрироваться</a></span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}