@page
@model WebSmartSchedule.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Управление пользователями";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Управление пользователями</h2>
        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createUserModal">
            <i class="bi bi-person-plus"></i> + Добавить пользователя
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0" style="max-height: 60vh; overflow-y: auto;">
            <table class="table table-hover mb-0">
                <thead class="table-light" style="position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th>Логин</th>
                        <th>Email</th>
                        <th>Роли</th>
                        <th class="text-end" style="padding-right: 1.5rem;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td class="align-middle">@user.Username</td>
                            <td class="align-middle">@user.Email</td>
                            <td class="align-middle">
                                @if (user.Roles.Any())
                                {
                                    foreach (var role in user.Roles)
                                    {
                                        var badgeClass = role == "Admin" ? "bg-danger" : "bg-primary";
                                        <span class="badge @badgeClass">@role</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Нет роли</span>
                                }
                            </td>
                            <td class="text-end align-middle" style="padding-right: 1.5rem;">
                                <button type="button" class="btn btn-sm btn-outline-primary me-1"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editUserModal"
                                        data-userid="@user.Id"
                                        data-username="@user.Username"
                                        data-email="@user.Email">
                                    Редактировать
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="modal"
                                        data-bs-target="#assignRoleModal"
                                        data-userid="@user.Id"
                                        data-username="@user.Username">
                                    Изменить роль
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="assignRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Назначить роль</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="AssignRole">
                <div class="modal-body">
                    <p>Пользователь: <strong id="modalRoleUserName"></strong></p>
                    <input type="hidden" id="modalRoleUserId" asp-for="RoleAssignInput.UserId" />

                    <div class="mb-3">
                        <label asp-for="RoleAssignInput.RoleName" class="form-label">Выберите новую роль</label>
                        <select class="form-select" asp-for="RoleAssignInput.RoleName" required>
                            <option value="" disabled selected>-- Выберите роль --</option>
                            <option value="Admin">Администратор (Admin)</option>
                            <option value="Teacher">Преподаватель (Teacher)</option>
                            <option value="Viewer">Зритель/Студент (Viewer)</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary">Сохранить</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="createUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Новый пользователь</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="CreateUser">
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="CreateInput.Username" class="form-label">Логин</label>
                        <input type="text" class="form-control" asp-for="CreateInput.Username" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="CreateInput.Email" class="form-label">Email</label>
                        <input type="email" class="form-control" asp-for="CreateInput.Email" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="CreateInput.Password" class="form-label">Пароль</label>
                        <input type="text" class="form-control" asp-for="CreateInput.Password" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="CreateInput.Role" class="form-label">Начальная роль</label>
                        <select class="form-select" asp-for="CreateInput.Role" required>
                            <option value="Viewer" selected>Зритель/Студент (Viewer)</option>
                            <option value="Teacher">Преподаватель (Teacher)</option>
                            <option value="Admin">Администратор (Admin)</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-success">Создать</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Редактировать пользователя</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="EditUser">
                <div class="modal-body">
                    <input type="hidden" id="modalEditUserId" asp-for="UpdateInput.UserId" />

                    <div class="mb-3">
                        <label asp-for="UpdateInput.Username" class="form-label">Логин</label>
                        <input type="text" class="form-control" id="modalEditUsername" asp-for="UpdateInput.Username" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdateInput.Email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="modalEditEmail" asp-for="UpdateInput.Email" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary">Сохранить изменения</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Заполнение данных для модалки назначения роли
        var assignRoleModal = document.getElementById('assignRoleModal')
        assignRoleModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget
            document.getElementById('modalRoleUserId').value = button.getAttribute('data-userid')
            document.getElementById('modalRoleUserName').textContent = button.getAttribute('data-username')
        })

        // Заполнение данных для модалки редактирования пользователя
        var editUserModal = document.getElementById('editUserModal')
        editUserModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget
            document.getElementById('modalEditUserId').value = button.getAttribute('data-userid')
            document.getElementById('modalEditUsername').value = button.getAttribute('data-username')
            document.getElementById('modalEditEmail').value = button.getAttribute('data-email')
        })
    </script>
}