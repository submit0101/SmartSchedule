@page
@model WebSmartSchedule.Pages.Building.IndexModel

<!-- Модальное окно создания здания -->
<div id="createBuildingModal" class="modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
    <div class="modal-content">
        <button class="btn-close" onclick="closeModal('createBuildingModal')"></button>
        <div class="modal-header mb-3">
            <h3>Добавить новое здание</h3>
        </div>
        <form method="post" asp-page-handler="Create" class="needs-validation" novalidate>
            <div class="form-group">
                <label for="createBuildingName" class="form-label">Название здания</label>
                <input type="text" class="form-control" id="createBuildingName" name="Name"
                       required maxlength="50" minlength="2"
                       pattern="^[a-zA-Zа-яА-Я0-9\s\-]+$"
                       oninput="this.value = this.value.replace(/[^a-zA-Zа-яА-Я0-9\s\-]/g, '')"
                       placeholder="Например: Главный корпус"
                       data-bs-toggle="tooltip"
                       data-bs-placement="top"
                       title="Разрешены: буквы, цифры, пробелы и дефис (2-50 символов)">
                <div class="invalid-feedback">От 2 до 50 символов (буквы, цифры, -)</div>
            </div>
            <div class="form-group">
                <label for="createBuildingAddress" class="form-label">Адрес здания</label>
                <input type="text" class="form-control" id="createBuildingAddress" name="Address"
                       required minlength="5" maxlength="255"
                       placeholder="Например: ул. Ленина, 15"
                       data-bs-toggle="tooltip"
                       data-bs-placement="top"
                       title="Укажите полный адрес (5-255 символов)">
                <div class="invalid-feedback">Адрес от 5 до 255 символов</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('createBuildingModal')">Отмена</button>
                <button type="submit" class="btn btn-primary">Добавить</button>
            </div>
        </form>
    </div>
</div>

<div id="editBuildingModal" class="modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
    <div class="modal-content">
        <button class="btn-close" onclick="closeModal('editBuildingModal')"></button>
        <div class="modal-header mb-3">
            <h3>Редактировать здание</h3>
        </div>
        <form method="post" asp-page-handler="Update" class="needs-validation" novalidate>
            <input type="hidden" id="editBuildingId" name="Id">
            <div class="form-group">
                <label for="editBuildingName" class="form-label">Название здания</label>
                <input type="text" class="form-control" id="editBuildingName" name="Name"
                       required maxlength="50" minlength="2"
                       pattern="^[a-zA-Zа-яА-Я0-9\s\-]+$"
                       oninput="this.value = this.value.replace(/[^a-zA-Zа-яА-Я0-9\s\-]/g, '')"
                       data-bs-toggle="tooltip"
                       data-bs-placement="top"
                       title="Разрешены: буквы, цифры, пробелы и дефис (2-50 символов)">
                <div class="invalid-feedback">От 2 до 50 символов (буквы, цифры, -)</div>
            </div>
            <div class="form-group">
                <label for="editBuildingAddress" class="form-label">Адрес здания</label>
                <input type="text" class="form-control" id="editBuildingAddress" name="Address"
                       required minlength="5" maxlength="255"
                       data-bs-toggle="tooltip"
                       data-bs-placement="top"
                       title="Укажите полный адрес (5-255 символов)">
                <div class="invalid-feedback">Адрес от 5 до 255 символов</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('editBuildingModal')">Отмена</button>
                <button type="submit" class="btn btn-primary">Сохранить</button>
            </div>
        </form>
    </div>
</div>

<!-- Модальное окно подтверждения удаления -->
<div id="deleteConfirmModal" class="modal">
    <div class="modal-content">
        <button class="btn-close" onclick="closeModal('deleteConfirmModal')">&times;</button>
        <div class="modal-header mb-3">
            <h3>Подтвердите удаление</h3>
        </div>
        <form method="post" asp-page-handler="Delete">
            <input type="hidden" id="deleteBuildingId" name="Id" />
            <p>Вы уверены, что хотите удалить это здание? Это действие нельзя будет отменить.</p>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('deleteConfirmModal')">Отмена</button>
                <button type="submit" class="btn btn-danger">Удалить</button>
            </div>
        </form>
    </div>
</div>
